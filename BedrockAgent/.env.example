# AWS CLI profile for Bedrock access (SSO or access-key profile)
AWS_PROFILE=myprofile

# AWS region for Bedrock calls
AWS_REGION=ap-northeast-1

# Set to 1 to use local .env/.env.local credentials instead of AgentCore Identity
LOCAL_DEV=1

# The following are only needed for non-Bedrock providers (OpenAI, Anthropic, Gemini, etc.)
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GEMINI_API_KEY=your-gemini-api-key
