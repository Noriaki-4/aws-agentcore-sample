{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "BedrockAgent",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "BedrockAgent"
  },
  "runtimes": [
    {
      "name": "BedrockAgent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/BedrockAgent/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "envVars": [
        {
          "name": "AGENTCORE_GATEWAY_URL",
          "value": "https://sample-manual-gw-s08lru8q3m.gateway.bedrock-agentcore.ap-northeast-1.amazonaws.com/mcp"
        }
      ],
      "connections": [
        {
          "id": "sample-manual-gateway",
          "to": {
            "type": "gateway",
            "arn": "arn:aws:bedrock-agentcore:ap-northeast-1:035351467732:gateway/sample-manual-gw-s08lru8q3m",
            "outboundAuth": { "awsIam": {} }
          },
          "description": "Manual Knowledge Base, reached through the AgentCore Gateway"
        }
      ]
    }
  ],
  "memories": [],
  "knowledgeBases": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "harnesses": [],
  "datasets": [],
  "payments": []
}